# ================================================================================================
# 🏗️ PROJECT-SPECIFIC CONFIGURATION (90-project.env)
# ================================================================================================
#
# Purpose: Project-specific overrides for spv-wallet
# Load Order: 90 (loaded last before local, overrides all prior defaults)
#
# This file contains configuration specific to the spv-wallet project that
# overrides defaults from the base env files (00-core, 10-*, 20-*).
#
# ================================================================================================

# ================================================================================================
# 🎯 GO VERSION CONFIGURATION
# ================================================================================================

# Primary Go version for builds and primary test runner
GO_PRIMARY_VERSION=1.25.x

# Secondary Go version for compatibility testing
GO_SECONDARY_VERSION=1.25.x

# MAGE-X Go version overrides
MAGE_X_GO_VERSION=1.25.x
MAGE_X_GO_SECONDARY_VERSION=1.25.x

# ================================================================================================
# 📊 COVERAGE PROVIDER
# ================================================================================================

# Use Codecov as the coverage provider
GO_COVERAGE_PROVIDER=codecov

# Codecov Configuration (only used when provider=codecov)
CODECOV_TOKEN_REQUIRED=true

# Coverage exclusions matching codecov.yml ignore paths
GO_COVERAGE_EXCLUDE_PATHS=.github/,.mage-cache/,.vscode/,bin/,example/,examples/,mocks/,testing/,test/,vendor/,testdata/

# ================================================================================================
# 📦 MULTI-MODULE TESTING
# ================================================================================================

# Enable multi-module testing (discovers all Go modules and merges coverage)
ENABLE_MULTI_MODULE_TESTING=true

# ================================================================================================
# 🔧 MAGE-X BUILD CONFIGURATION
# ================================================================================================

# Exclude regression tests from build tag auto-discovery (they require Docker, external APIs, and long sync times)
MAGE_X_AUTO_DISCOVER_BUILD_TAGS_EXCLUDE=race,custom,database_tests,manualtests,regression-tests
MAGE_X_BUILD_EXCLUDE_PATTERN=database_tests,manualtests,regression-tests
MAGE_X_TEST_EXCLUDE_MODULES=database_tests,manualtests,regression-tests

# Module: manualtests - This is intended to actually be run by a developer manually
# Module: database_tests - These tests require a database to be available
# Module: regression-tests - These tests are long-running and require external dependencies

# ================================================================================================
# 🔒 SECURITY EXCLUSIONS
# ================================================================================================

# CVE-2026-26958: filippo.io/edwards25519 - upgraded to v1.2.0 which includes the fix
# Kept as exclusion in case Nancy flags the old version hash still present in go.sum
NANCY_EXCLUDES=CVE-2026-34986
MAGE_X_CVE_EXCLUDES=CVE-2026-34986,CVE-2026-33997,CVE-2026-34040
